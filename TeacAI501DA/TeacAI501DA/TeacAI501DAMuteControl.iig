#ifndef TeacAI501DAMuteControl_h
#define TeacAI501DAMuteControl_h

#include <AudioDriverKit/IOUserAudioBooleanControl.iig>

class TeacAI501DA;

class LOCALONLY TeacAI501DAMuteControl : public IOUserAudioBooleanControl
{
public:
    virtual bool init(IOUserAudioDriver* in_driver,
                      bool in_is_settable,
                      bool in_control_value,
                      IOUserAudioObjectPropertyElement in_control_element,
                      IOUserAudioObjectPropertyScope in_control_scope,
                      IOUserAudioClassID in_control_class_id) override;
    virtual void free() override;

    virtual kern_return_t HandleChangeControlValue(bool in_control_value) override;

    /*! Back-reference to the driver that owns the gain state. */
    virtual void SetDriverRef(TeacAI501DA* in_driver) LOCALONLY;
};

#endif /* TeacAI501DAMuteControl_h */
